# Supabase — DriveData Academy
# Copie para .env.local e preencha. NÃO comite .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon

# SECRETO — só no servidor. Configure também nas Environment Variables do Vercel.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# E-mails com acesso ao portal /admin (separados por vírgula)
ADMIN_EMAILS=email@dominio.com

# Resend — envio de e-mail dos materiais (opcional; sem isso, entrega só por download na página)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=DriveData Academy <materiais@drivedata.com.br>
